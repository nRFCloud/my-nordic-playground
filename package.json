{
  "name": "@nrfcloud/my-nordic-playground",
  "version": "0.0.0-development",
  "description": "My Nordic Playground",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nRFCloud/my-nordic-playground.git"
  },
  "bugs": {
    "url": "https://github.com/nRFCloud/my-nordic-playground/issues"
  },
  "keywords": [
    "nordicsemiconductor",
    "nrfcloud",
    "my-nordic"
  ],
  "author": "Nordic Semiconductor ASA | nordicsemi.no",
  "license": "UNLICENSED",
  "scripts": {
    "start": "vite",
    "build": "node --max_old_space_size=8192 ./node_modules/vite/bin/vite.js build --emptyOutDir",
    "prepare": "husky && check-node-version --package",
    "test": "node --no-warnings --experimental-transform-types --test \"!(node_modules|e2e-tests)/**/*.spec.ts\""
  },
  "dependencies": {
    "@azure/msal-browser": "5.4.0",
    "bootstrap": "5.3.8",
    "compare-versions": "6.1.1",
    "date-fns": "4.1.0",
    "preact": "10.28.4",
    "preact-iso": "2.11.1"
  },
  "devDependencies": {
    "@babel/plugin-syntax-import-assertions": "7.28.6",
    "@bifravst/eslint-config-typescript": "6.4.4",
    "@bifravst/from-env": "3.0.2",
    "@bifravst/prettier-config": "1.1.17",
    "@commitlint/config-conventional": "20.4.3",
    "@preact/preset-vite": "2.10.3",
    "@swc/core": "1.15.18",
    "@types/node": "25.3.3",
    "@typescript/native-preview": "7.0.0-dev.20260304.1",
    "check-node-version": "4.2.1",
    "commitlint": "20.4.3",
    "handlebars": "4.7.8",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.{md,json,yaml,yml,html,css}": [
      "prettier --write"
    ]
  },
  "prettier": "@bifravst/prettier-config",
  "release": {
    "branches": [
      "main"
    ],
    "remoteTags": true,
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/github",
        {
          "successCommentCondition": false,
          "failTitle": false
        }
      ]
    ]
  }
}
